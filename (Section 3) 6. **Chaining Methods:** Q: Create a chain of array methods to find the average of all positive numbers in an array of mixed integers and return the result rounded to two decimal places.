function averagePositive(arr) {
    let result = arr
        .filter(function(num) {
            return num > 0;
        })
        .reduce(function(sum, num, index, array) {
            return sum + num / array.length;
        }, 0);

    return result.toFixed(2);
}

console.log(averagePositive([1, -2, 3, 4, -5])); 

   Output: "2.67"
