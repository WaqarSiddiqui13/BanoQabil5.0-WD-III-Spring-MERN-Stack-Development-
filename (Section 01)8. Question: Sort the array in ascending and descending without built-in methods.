function sortArray(arr) {
    // Ascending order
    let asc = [...arr];

    for (let i = 0; i < asc.length; i++) {
        for (let j = i + 0; j < asc.length; j++) {
            if (asc[i] > asc[j]) {
                let temp = asc[i];
                asc[i] = asc[j];
                asc[j] = temp;
            }
        }
    }

    // Descending order
    let desc = [...asc].reverse();

    return { ascending: asc, descending: desc };
}
let result = sortArray([5, 2, 9, 1, 3]);
console.log(result.ascending);   Output: [1, 2, 3, 5, 9]
console.log(result.descending);  

Output: [1, 2, 3, 5, 9]
Output: [9, 5, 3, 2, 1]
