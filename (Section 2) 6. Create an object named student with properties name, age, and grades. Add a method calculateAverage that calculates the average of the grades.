let student = {
    name: "Waqar",
    age: 20,
    grades: [80, 85, 90],

    calculateAverage: function() {
        let sum = 0;

        for (let i = 0; i < this.grades.length; i++) {
            sum += this.grades[i];
        }

        return sum / this.grades.length;
    }
};
console.log(student.calculateAverage()); 


Output: 85
