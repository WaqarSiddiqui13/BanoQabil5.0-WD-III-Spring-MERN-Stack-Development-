function updateStatus(arr, targetId) {
    let item = arr.find(function(obj) {
        return obj.id === targetId;
    });

    if (item) {
        item.status = "completed";
    }

    return arr;
}


let tasks = [
    { id: 1, status: "pending" },
    { id: 2, status: "pending" },
    { id: 3, status: "pending" }
];

console.log(updateStatus(tasks, 2));
